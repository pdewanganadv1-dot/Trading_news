# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Groq LLM (get API key at https://console.groq.com/keys)
GROQ_API_KEY=

# DhanHQ Broker (get from Dhan dashboard)
DHAN_CLIENT_ID=
DHAN_ACCESS_TOKEN=

# Signal settings
SIGNAL_CONFIDENCE_THRESHOLD=0.65
SIGNAL_CHECK_INTERVAL_SECONDS=600

# Persistent storage (defaults to ./data/)
PERSISTENT_DIR=

# Groq model
GROQ_MODEL=llama-3.3-70b-versatile
